# -----------------------------------------------------------------------------
# SWARNA LEDGER - ENVIRONMENT VARIABLES TEMPLATE
# -----------------------------------------------------------------------------
# Copy this file to .env in your respective directories or use these keys 
# when setting up deployment environments (like Render).
# -----------------------------------------------------------------------------

# ==========================================
# SERVER CONFIGURATION (For Render / server directory)
# ==========================================
NODE_ENV=production
PORT=10000

# Security (Generate a secure random string for production)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Supabase Admin Access (Required for backend admin tasks)
# Get this from Supabase Dashboard -> Project Settings -> API -> service_role
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# CORS Configuration (Must point to your frontend domain)
CORS_ORIGIN=https://swarna-client.onrender.com


# ==========================================
# CLIENT CONFIGURATION (For Render / client directory)
# ==========================================
VITE_APP_ENV=production

# Server API URL (Must point to your backend domain)
VITE_API_BASE_URL=https://swarna-server.onrender.com/api

# Supabase Public Access (Required for frontend auth)
# Get this from Supabase Dashboard -> Project Settings -> API -> anon public
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
